# Database — Local PostgreSQL (run: createdb fal)
DATABASE_URL="postgresql://YOUR_USERNAME@localhost/fal"

# Auth.js v5
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# SportMonks Cricket API (sign up at sportmonks.com, €29/mo)
SPORTMONKS_API_TOKEN="your-api-token-here"

# IPL 2026 Season (validated)
SPORTMONKS_SEASON_ID="1795"
SPORTMONKS_LEAGUE_ID="1"

# Vercel Cron (any secret for dev, auto-generated in production)
CRON_SECRET="dev-cron-secret"

# Admin bootstrap secret — used to create the first admin account via the login page
ADMIN_SECRET="change-me-to-a-random-secret"
